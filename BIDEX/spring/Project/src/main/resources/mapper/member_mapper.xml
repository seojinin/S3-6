<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="pj.notice.mapper.MemberMapper">

    <insert id="insertMember">

        INSERT INTO tb_member
        (
            login_id,
            password,
            username,
            email,
            phone
        )

        VALUES
        (
            #{loginId},
            #{password},
            #{username},
            #{email},
            #{phone}
        )

    </insert>

    <select id="selectByLoginId"
            resultType="pj.notice.model.MemberModel">

        SELECT *
        FROM tb_member
        WHERE login_id = #{loginId}

    </select>

    <select id="selectByMemberId"
            resultType="pj.notice.model.MemberModel">

        SELECT *
        FROM tb_member
        WHERE member_id = #{memberId}

    </select>

	<update id="updateMember">
	
	    UPDATE tb_member
	
	    SET
	
	        username = #{username},
	        email = #{email},
	        phone = #{phone}
	
	    WHERE member_id = #{memberId}
	
	</update>

</mapper>